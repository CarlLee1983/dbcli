# ============================================
# Database Configuration Examples
# ============================================

# 方式 1: 使用完整的 DATABASE_URL 連接字符串 (推薦)
# ============================================
# DATABASE_URL=mysql://root:password@localhost:3306/testing
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# DATABASE_URL=mariadb://root:password@localhost:3306/testing

# 密碼中的特殊字符需要用百分比編碼:
# @ 編碼為 %40
# # 編碼為 %23
# : 編碼為 %3A
# 例: 密碼 "p@ss#word" 應寫為 "p%40ss%23word"


# 方式 2: 使用分開的 DB_* 環境變量
# ============================================
# DB_SYSTEM=mysql              # 數據庫系統: mysql, mariadb, postgresql
# DB_HOST=localhost            # 主機地址
# DB_PORT=3306                 # 埠號 (可選，有默認值)
# DB_USER=root                 # 用戶名 (必需)
# DB_PASSWORD=password         # 密碼 (可選)
# DB_NAME=testing              # 數據庫名 (必需)


# ============================================
# 其他配置
# ============================================

# Bun 會自動加載這個文件
# 環境變量優先順序:
# 1. 命令行參數 (--user, --host 等)
# 2. 環境變量 (DATABASE_URL 或 DB_*)
# 3. 交互提示 (init 命令會提示輸入缺少的值)
